<mvc:View controllerName="zleave.zleave.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core">

    <f:DynamicPage id="dashboardPage" headerExpanded="true" preserveHeaderStateOnScroll="false" fitContent="true">

        <!-- ─── TITLE ────────────────────────────────────────── -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Leave Management" level="H3" />
                </f:heading>
                <f:snappedHeading>
                    <Title text="Leave Management" level="H3" />
                </f:snappedHeading>
                <f:expandedContent>
                    <Text text="{= 'Welcome, ' + ${ui>/currentUser/employeeName}}" />
                </f:expandedContent>
                <f:snappedContent>
                    <Text text="{ui>/currentUser/employeeName}" />
                </f:snappedContent>
                <f:actions>
                    <Button id="btnTitleCreate"
                        text="New Request"
                        type="Emphasized"
                        icon="sap-icon://create"
                        press=".onNavToCreate" />
                    <Button id="btnTitleMyReq"
                        text="My Requests"
                        icon="sap-icon://employee"
                        press=".onNavToRequests" />
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <!-- ─── HEADER (Employee Details) ────────── -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <HBox wrap="Wrap" class="sapUiSmallMarginTop sapUiSmallMarginBottom" justifyContent="Start">
                    <VBox class="sapUiLargeMarginEnd sapUiTinyMarginBottom">
                        <Label text="Employee ID" class="sapUiTinyMarginBottom" design="Bold"/>
                        <Text text="{ui>/currentUser/employeeId}"/>
                    </VBox>
                    <VBox class="sapUiTinyMarginBottom">
                        <Label text="Roles &amp; Permissions" class="sapUiTinyMarginBottom" design="Bold"/>
                        <ObjectStatus text="{ui>/currentUser/accessRolesText}" state="Success"/>
                    </VBox>
                </HBox>
            </f:DynamicPageHeader>
        </f:header>

        <!-- ─── CONTENT ──────────────────────────────────────── -->
        <f:content>
            <l:Grid
                defaultSpan="XL12 L12 M12 S12"
                hSpacing="1" vSpacing="1"
                class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">

                <!-- Leave Balance (8 columns) -->
                <VBox>
                    <layoutData><l:GridData span="XL8 L8 M12 S12" /></layoutData>
                    <Panel id="panelLeaveBalance"
                        headerText="Leave Balance"
                        class="sapUiSmallMarginBottom"
                        expandable="false"
                        backgroundDesign="Translucent">
                        <FlexBox wrap="Wrap" class="sapUiTinyMarginTop" items="{quota>/results}">
                            <GenericTile
                                header="{quota>LeaveTypeName}"
                                subheader="Remaining"
                                class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                                press=".onTilePress">
                                <tileContent>
                                    <TileContent footer="{= 'Used: ' + ${quota>UsedDays} + ' / ' + ${quota>TotalDays} + ' days'}">
                                        <content>
                                            <NumericContent
                                                value="{quota>RemainingDays}"
                                                valueColor="{= ${quota>RemainingDays} > 5 ? 'Good' : ${quota>RemainingDays} > 0 ? 'Critical' : 'Error'}"
                                                indicator="None" />
                                        </content>
                                    </TileContent>
                                </tileContent>
                            </GenericTile>
                        </FlexBox>
                        <Text
                            text="No leave balance data available."
                            visible="{= !${quota>/results} || ${quota>/results}.length === 0 }"
                            class="sapUiSmallMargin" />
                    </Panel>
                </VBox>

                <!-- Quick Actions (4 columns) -->
                <VBox>
                    <layoutData><l:GridData span="XL4 L4 M12 S12" /></layoutData>
                    <Panel id="panelQuickActions"
                        headerText="Quick Actions"
                        class="sapUiSmallMarginBottom"
                        expandable="false"
                        backgroundDesign="Translucent">
                        <List id="listQuickActions" showSeparators="Inner">
                            <StandardListItem
                                id="qaCreate"
                                title="Create Leave Request"
                                icon="sap-icon://create"
                                type="Navigation"
                                press=".onNavToCreate" />
                            <StandardListItem
                                id="qaMyRequests"
                                title="View My Requests"
                                icon="sap-icon://employee"
                                type="Navigation"
                                press=".onNavToRequests" />
                        </List>
                    </Panel>
                </VBox>

            </l:Grid>
        </f:content>

    </f:DynamicPage>
</mvc:View>
