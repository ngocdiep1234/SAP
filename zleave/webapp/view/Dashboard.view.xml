<mvc:View controllerName="zleave.zleave.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core">
    <Page id="dashboardPage" title="Leave Management Dashboard" showHeader="true">
        <headerContent>
            <HBox alignItems="Center" class="sapUiSmallMarginEnd">
                <core:Icon src="sap-icon://employee" size="1rem" class="sapUiSmallMarginEnd" color="#0064d9"/>
                <Text id="txtCurrentUser" text="{ui>/currentUser/displayName}" class="sapUiSmallMarginEnd" design="Bold"/>
                <Button
                    id="btnLogout"
                    icon="sap-icon://log"
                    tooltip="Logout"
                    type="Transparent"
                    press=".onLogout"/>
            </HBox>
        </headerContent>
        <content>
            <l:Grid id="dashboardGrid" defaultSpan="XL12 L12 M12 S12" hSpacing="1" vSpacing="1" class="sapUiSmallMargin">
                
                <!-- Left Column (70%) -->
                <VBox id="leftContainer">
                    <layoutData>
                        <l:GridData span="XL8 L8 M12 S12"/>
                    </layoutData>

                    <!-- Leave Balance Section -->
                    <Panel headerText="Leave Balance" class="sapUiSmallMarginBottom" backgroundDesign="Translucent">
                        <FlexBox wrap="Wrap" justify="SpaceBetween" class="sapUiTinyMarginTop">
                            <GenericTile header="Annual Leave" subheader="Remaining" class="sapUiTinyMarginEnd sapUiTinyMarginBottom" press=".onTilePress">
                                <tileContent>
                                    <TileContent>
                                        <content>
                                            <NumericContent value="{ui>/dashboard/annualLeaveRemaining}" valueColor="{= ${ui>/dashboard/annualLeaveRemaining} > 5 ? 'Good' : ${ui>/dashboard/annualLeaveRemaining} > 2 ? 'Critical' : 'Error' }" indicator="None"/>
                                        </content>
                                    </TileContent>
                                </tileContent>
                            </GenericTile>

                            <GenericTile header="Sick Leave" subheader="Remaining" class="sapUiTinyMarginEnd sapUiTinyMarginBottom" press=".onTilePress">
                                <tileContent>
                                    <TileContent>
                                        <content>
                                            <NumericContent value="{ui>/dashboard/sickLeaveRemaining}" valueColor="{= ${ui>/dashboard/sickLeaveRemaining} > 2 ? 'Good' : 'Error' }" indicator="None"/>
                                        </content>
                                    </TileContent>
                                </tileContent>
                            </GenericTile>

                            <GenericTile header="Unpaid Leave" subheader="Used" class="sapUiTinyMarginBottom" press=".onTilePress">
                                <tileContent>
                                    <TileContent>
                                        <content>
                                            <NumericContent value="{ui>/dashboard/unpaidLeaveUsed}" valueColor="Neutral" indicator="None"/>
                                        </content>
                                    </TileContent>
                                </tileContent>
                            </GenericTile>
                        </FlexBox>
                    </Panel>

                    <!-- Quick Actions Section -->
                    <Panel headerText="Quick Actions" class="sapUiSmallMarginBottom" backgroundDesign="Translucent">
                        <HBox wrap="Wrap" class="sapUiTinyMarginTop">
                            <Button text="Create Leave Request" type="Emphasized" icon="sap-icon://create" press=".onNavToCreate" class="sapUiSmallMarginEnd sapUiTinyMarginBottom"/>
                            <Button text="My Requests" icon="sap-icon://employee" press=".onNavToRequests" class="sapUiSmallMarginEnd sapUiTinyMarginBottom"/>
                            <Button text="Leave Calendar" icon="sap-icon://appointment-2" press=".onNavToCalendar" class="sapUiTinyMarginBottom"/>
                        </HBox>
                    </Panel>

                    <!-- Leave Requests Section -->
                    <Panel headerText="Leave Requests" backgroundDesign="Translucent">
                        <Table id="tableRecentRequests" inset="false" items="{ui>/dashboard/myRequests}">
                            <columns>
                                <Column width="7rem"><Text text="Request ID" design="Bold"/></Column>
                                <Column><Text text="Leave Type" design="Bold"/></Column>
                                <Column minScreenWidth="Tablet" demandPopin="true"><Text text="Date Range" design="Bold"/></Column>
                                <Column width="6rem" hAlign="End"><Text text="Total Days" design="Bold"/></Column>
                                <Column width="8rem" hAlign="Center"><Text text="Status" design="Bold"/></Column>
                                <Column width="10rem" hAlign="End"><Text text="Actions" design="Bold"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{ui>RequestId}"/>
                                        <Text text="{ui>LeaveType}"/>
                                        <Text text="{path: 'ui>StartDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'yyyy-MM-dd'}} → {path: 'ui>EndDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'yyyy-MM-dd'}}"/>
                                        <Text text="{path: 'ui>TotalDays', type: 'sap.ui.model.type.Float', formatOptions: {minFractionDigits: 0, maxFractionDigits: 1}}"/>
                                        <ObjectStatus text="{ui>Status}" state="{= ${ui>Status} === 'Approved' ? 'Success' : ${ui>Status} === 'Rejected' ? 'Error' : (${ui>Status} === 'Submitted' || ${ui>Status} === 'SUBMITTED' || ${ui>Status} === 'Pending') ? 'Warning' : 'None' }"/>
                                        <HBox justify="End" alignWidth="true">
                                            <Button icon="sap-icon://hint" type="Transparent" press=".onViewRequest" tooltip="View Details"/>
                                            <Button icon="sap-icon://edit" type="Transparent" press=".onEditRequest" visible="{= ${ui>Status} === 'Draft' }" tooltip="Edit Draft"/>
                                            <Button icon="sap-icon://delete" type="Transparent" press=".onDeleteRequest" visible="{= ${ui>Delete_mc} !== undefined ? ${ui>Delete_mc} === true : (${ui>Status} === 'Draft' || ${ui>Status} === 'Submitted' || ${ui>Status} === 'SUBMITTED' || ${ui>Status} === 'Pending') }" tooltip="Delete Request"/>
                                        </HBox>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </Panel>
                </VBox>
                
                <!-- Right Column (30%) -->
                <VBox id="rightContainer">
                    <layoutData>
                        <l:GridData span="XL4 L4 M12 S12"/>
                    </layoutData>

                    <!-- Upcoming Leaves Section -->
                    <Panel headerText="Upcoming Leaves" class="sapUiSmallMarginBottom" backgroundDesign="Translucent">
                        <List id="listUpcomingLeaves" 
                            noDataText="No upcoming leaves approved"
                            items="{ui>/dashboard/upcomingLeaves}">
                            <StandardListItem 
                                title="{ui>LeaveType} Leave"
                                description="{path: 'ui>StartDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'yyyy-MM-dd'}} ({ui>TotalDays} Days)"
                                icon="sap-icon://calendar"
                                info="{ui>Status}"
                                infoState="Success"/>
                        </List>
                    </Panel>

                    <!-- System Notifications Section -->
                    <Panel headerText="Notifications" backgroundDesign="Translucent">
                        <List id="listNotifications" 
                            items="{ui>/dashboard/notifications}">
                            <CustomListItem>
                                <HBox class="sapUiSmallMargin" alignItems="Center">
                                    <core:Icon src="{ui>icon}" color="{= ${ui>state} === 'Success' ? '#2b7c2b' : ${ui>state} === 'Error' ? '#bb0000' : '#0066cc' }" class="sapUiSmallMarginEnd"/>
                                    <VBox>
                                        <Text text="{ui>message}" design="Bold"/>
                                        <Text text="{ui>time}" class="sapUiTinyMarginTop" style="font-size: 0.8rem; color: #666;"/>
                                    </VBox>
                                </HBox>
                            </CustomListItem>
                        </List>
                    </Panel>
                </VBox>
            </l:Grid>
        </content>
    </Page>
</mvc:View>
