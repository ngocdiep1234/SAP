<mvc:View
    controllerName="zleave.zleave.controller.admin.AdminQuotaManagement"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    height="100%">
    <Page title="Quota Management" showHeader="true">
        <headerContent>
            <SearchField
                id="searchField"
                width="300px"
                placeholder="Search by Employee, User, Type..."
                search=".onSearch"/>
        </headerContent>
        <content>
            <Table
                id="tableQuota"
                width="auto"
                items="{
                    path: '/QuotaOverview',
                    sorter: [
                        { path: 'QuotaYear', descending: true },
                        { path: 'FullName' }
                    ]
                }"
                growing="true"
                growingThreshold="20"
                mode="None"
                class="sapUiResponsiveMargin employeeTable">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="Employee Leave Quotas" level="H2"/>
                        <ToolbarSpacer />
                        <Button
                            icon="sap-icon://refresh"
                            text="Refresh"
                            press=".onRefresh"/>
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column minScreenWidth="Tablet" demandPopin="true">
                        <Text text="Employee" />
                    </Column>
                    <Column width="10rem">
                        <Text text="Department" />
                    </Column>
                    <Column minScreenWidth="Tablet" demandPopin="true">
                        <Text text="Leave Type" />
                    </Column>
                    <Column width="5rem" hAlign="Center">
                        <Text text="Year" />
                    </Column>
                    <Column width="6rem" hAlign="End">
                        <Text text="Total" />
                    </Column>
                    <Column width="6rem" hAlign="End">
                        <Text text="Used" />
                    </Column>
                    <Column width="7rem" hAlign="End">
                        <Text text="Remaining" />
                    </Column>
                    <Column minScreenWidth="Desktop" demandPopin="true" hAlign="Center">
                        <Text text="Validity Period" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{parts: [{path: 'FullName'}, {path: 'EmployeeId'}], formatter: '.formatEmployeeName'}" />
                            <Text text="{Department}" />
                            <Text text="{LeaveTypeName} ({LeaveTypeId})" />
                            <Text text="{QuotaYear}" />
                            <Text text="{path: 'TotalDays', type: 'sap.ui.model.type.Float', formatOptions: {maxFractionDigits: 1}}" />
                            <Text text="{path: 'UsedDays', type: 'sap.ui.model.type.Float', formatOptions: {maxFractionDigits: 1}}" />
                            <ObjectStatus
                                text="{path: 'RemainingDays', type: 'sap.ui.model.type.Float', formatOptions: {maxFractionDigits: 1}}"
                                state="{path: 'RemCriticality', formatter: '.formatCriticalityState'}"/>
                            <Text text="{parts: [{path: 'ValidFrom'}, {path: 'ValidTo'}], formatter: '.formatDateRange'}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
