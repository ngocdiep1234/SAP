<mvc:View controllerName="zleave.zleave.controller.admin.AdminLeaveRequests"
    xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page id="requestsPage" title="{i18n>leaveRequests}">
        <headerContent>
            <Button text="{i18n>create}" icon="sap-icon://add" press=".onNavToCreate" type="Emphasized"/>
        </headerContent>
        <content>
            <VBox>
                <SearchField id="filterEmployeeRequests" placeholder="{i18n>employee}" search=".onFilter" width="18rem" class="tableFilter"/>
                <SegmentedButton id="filterStatusButton" select=".onFilterTabChange" selectedKey="{ui>/selectedAdminRequestTab}" class="sapUiSmallMarginBottom">
                    <items>
                        <SegmentedButtonItem key="all" text="All Requests" />
                        <SegmentedButtonItem key="pending" text="Pending Approval" />
                    </items>
                </SegmentedButton>
                <SegmentedButton id="pendingRequestsSubFilterButton" select=".onPendingSubFilterTabChange" selectedKey="{ui>/selectedAdminPendingSubTab}" visible="{= ${ui>/selectedAdminRequestTab} === 'pending' || !${ui>/selectedAdminRequestTab} }" class="sapUiSmallMarginBottom">
                    <items>
                        <SegmentedButtonItem key="normal" text="Normal Request" />
                        <SegmentedButtonItem key="warning" text="Warnings" />
                    </items>
                </SegmentedButton>
                <Table id="tableRequests" mode="MultiSelect" selectionChange=".onSelectionChange" inset="false" items="{/LeaveRequestAdmin}" growing="true" growingScrollToLoad="true" class="leaveTable">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="{i18n>leaveRequests}" level="H2"/>
                            <ToolbarSpacer/>
                            <Button id="btnApproveSelected" text="{i18n>approveSelected}" icon="sap-icon://accept" type="Accept" press=".onApproveSelected" enabled="false" visible="{= ${ui>/currentUser/is_admin} !== 'X' }"/>
                            <Button id="btnRejectSelected" text="{i18n>rejectSelected}" icon="sap-icon://decline" type="Reject" press=".onRejectSelected" enabled="false" visible="{= ${ui>/currentUser/is_admin} !== 'X' }"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column><Text text="{i18n>requestId}"/></Column>
                        <Column><Text text="{i18n>employeeName}"/></Column>
                        <Column><Text text="{i18n>leaveType}"/></Column>
                        <Column><Text text="{i18n>startDate}"/></Column>
                        <Column><Text text="{i18n>endDate}"/></Column>
                        <Column><Text text="{i18n>totalDays}"/></Column>
                        <Column visible="{= ${ui>/selectedAdminRequestTab} === 'pending' || !${ui>/selectedAdminRequestTab} }"><Text text="Warning"/></Column>
                        <Column><Text text="{i18n>status}"/></Column>
                    </columns>
                    <items>
                        <ColumnListItem type="Active" press=".onItemPress" highlight="{parts: [{path: 'StartDate'}, {path: 'CreatedAt'}, {path: 'TotalDays'}, {path: 'ui>/selectedAdminRequestTab'}], formatter: '.formatRowHighlight'}">
                            <cells>
                                <Text text="{RequestId}"/>
                                <Text text="{parts: [{path: 'EmployeeId'}, {path: 'ui>/employeesMap'}], formatter: '.formatEmployeeName'}"/>
                                <Text text="{LeaveType}"/>
                                <Text text="{path: 'StartDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'yyyy-MM-dd'}}"/>
                                <Text text="{path: 'EndDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'yyyy-MM-dd'}}"/>
                                <Text text="{path: 'TotalDays', type: 'sap.ui.model.type.Float', formatOptions: {minFractionDigits: 0, maxFractionDigits: 1}}"/>
                                <ObjectStatus
                                    text="{parts: [{path: 'StartDate'}, {path: 'CreatedAt'}, {path: 'TotalDays'}], formatter: '.formatAbnormalReason'}"
                                    state="Error"
                                    icon="sap-icon://message-warning"
                                    visible="{parts: [{path: 'StartDate'}, {path: 'CreatedAt'}, {path: 'TotalDays'}, {path: 'ui>/selectedAdminRequestTab'}], formatter: '.formatAbnormalVisible'}"/>
                                <ObjectStatus text="{Status}" state="{= ${Status} === 'Approved' ? 'Success' : ${Status} === 'Rejected' ? 'Error' : 'Warning' }"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
