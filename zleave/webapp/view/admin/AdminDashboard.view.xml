<mvc:View
    controllerName="zleave.zleave.controller.admin.AdminDashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    height="100%">
    <f:DynamicPage id="adminDashboardPage" headerExpanded="true" preserveHeaderStateOnScroll="false" fitContent="true">
        <!-- ─── TITLE ────────────────────────────────────────── -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Leave Management" level="H3" />
                </f:heading>
                <f:snappedHeading>
                    <Title text="Leave Management" level="H3" />
                </f:snappedHeading>
                <f:expandedContent>
                    <Text text="{= 'Welcome, ' + ${ui>/currentUser/employeeName}}" />
                </f:expandedContent>
                <f:snappedContent>
                    <Text text="{ui>/currentUser/employeeName}" />
                </f:snappedContent>
            </f:DynamicPageTitle>
        </f:title>

        <!-- ─── HEADER (Employee Details) ────────── -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <HBox wrap="Wrap" class="sapUiSmallMarginTop sapUiSmallMarginBottom" justifyContent="Start">
                    <VBox class="sapUiLargeMarginEnd sapUiTinyMarginBottom">
                        <Label text="Employee ID" class="sapUiTinyMarginBottom" design="Bold"/>
                        <Text text="{ui>/currentUser/employeeId}"/>
                    </VBox>
                    <VBox class="sapUiTinyMarginBottom">
                        <Label text="Roles &amp; Permissions" class="sapUiTinyMarginBottom" design="Bold"/>
                        <ObjectStatus text="{ui>/currentUser/accessRolesText}" state="Success"/>
                    </VBox>
                </HBox>
            </f:DynamicPageHeader>
        </f:header>

        <!-- ─── CONTENT ──────────────────────────────────────── -->
        <f:content>
            <l:Grid defaultSpan="XL12 L12 M12 S12" hSpacing="1" vSpacing="1" class="sapUiSmallMargin">
                

                <!-- Left Column (70%) - Audit Log (Recent Activities) -->
                <VBox>
                    <layoutData>
                        <l:GridData span="XL8 L8 M12 S12"/>
                    </layoutData>

                    <!-- Recent Activity Stream -->
                    <Panel headerText="Recent Activities" backgroundDesign="Translucent">
                        <List id="listActivities" 
                            items="{mock>/recentActivities}">
                            <CustomListItem>
                                <HBox class="sapUiSmallMargin" alignItems="Center">
                                    <core:Icon src="{mock>icon}" color="{= ${mock>state} === 'Success' ? '#2b7c2b' : '#0066cc' }" class="sapUiSmallMarginEnd"/>
                                    <VBox>
                                        <Text text="{mock>text}" design="Bold"/>
                                        <Text text="{mock>time}" class="sapUiTinyMarginTop" style="font-size: 0.8rem; color: #666;"/>
                                    </VBox>
                                </HBox>
                            </CustomListItem>
                        </List>
                    </Panel>
                </VBox>

                <!-- Right Column (30%) - Quick Admin Actions -->
                <VBox>
                    <layoutData>
                        <l:GridData span="XL4 L4 M12 S12"/>
                    </layoutData>

                    <!-- Quick Admin Controls -->
                    <Panel headerText="Quick Admin Actions" class="sapUiSmallMarginBottom" backgroundDesign="Translucent">
                        <VBox class="sapUiTinyMarginTop">
                            <Button text="Add New Employee" type="Emphasized" icon="sap-icon://add-employee" press=".onNavToEmployees" class="sapUiTinyMarginBottom" width="100%"/>
                            <Button text="Process Leave Requests" icon="sap-icon://approvals" press=".onNavToLeaveRequests" class="sapUiTinyMarginBottom" width="100%"/>
                            <Button text="Check Quota Allocation" icon="sap-icon://check-availability" press=".onNavToQuota" class="sapUiTinyMarginBottom" width="100%"/>
                            <Button text="Manage Leave Types" icon="sap-icon://list" press=".onNavToLeaveTypes" width="100%"/>
                        </VBox>
                    </Panel>
                </VBox>

            </l:Grid>
        </f:content>
    </f:DynamicPage>
</mvc:View>
