<mvc:View controllerName="zleave.zleave.controller.Requests"
    xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m">
    <Page id="requestsPage" title="{i18n>leaveRequests}">
        <content>
            <VBox>
                <SearchField id="filterEmployeeRequests" placeholder="{i18n>employee}" search=".onFilter" width="18rem" class="tableFilter"/>
                <Table id="tableRequests" inset="false" items="{/LeaveRequest}" growing="true" growingScrollToLoad="true" class="leaveTable">
                    <columns>
                        <Column><Text text="{i18n>requestId}"/></Column>
                        <Column><Text text="{i18n>employeeId}"/></Column>
                        <Column><Text text="{i18n>departmentId}"/></Column>
                        <Column><Text text="{i18n>leaveType}"/></Column>
                        <Column><Text text="{i18n>startDate}"/></Column>
                        <Column><Text text="{i18n>endDate}"/></Column>
                        <Column><Text text="{i18n>totalDays}"/></Column>
                        <Column><Text text="{i18n>status}"/></Column>
                        <Column><Text text="{i18n>actions}"/></Column>
                    </columns>
                    <items>
                        <ColumnListItem type="Active">
                            <cells>
                                <Text text="{RequestID}"/>
                                <Text text="{EmployeeID}"/>
                                <Text text="{DepartmentID}"/>
                                <Text text="{LeaveType}"/>
                                <Text text="{path: 'StartDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'yyyy-MM-dd'}}"/>
                                <Text text="{path: 'EndDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'yyyy-MM-dd'}}"/>
                                <Text text="{TotalDays}"/>
                                <ObjectStatus text="{Status}" state="{= ${Status} === 'Approved' ? 'Success' : ${Status} === 'Rejected' ? 'Error' : 'Warning' }"/>
                                <HBox>
                                    <Button text="{i18n>approve}" type="Accept" press=".onApprove" visible="{= ${Status} === 'Pending' }"/>
                                    <Button text="{i18n>reject}" type="Reject" press=".onReject" visible="{= ${Status} === 'Pending' }"/>
                                    <Button icon="sap-icon://attachment" press=".onOpenAttachment" tooltip="{i18n>attachment}"/>
                                </HBox>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
