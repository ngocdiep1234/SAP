<mvc:View controllerName="zleave.zleave.controller.CreateRequest"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:unified="sap.ui.unified">
    <Page id="createRequestPage"
        title="{i18n>createLeaveRequestTitle}"
        showNavButton="true"
        navButtonPress=".onNavBack"
        showFooter="true">
        <content>
            <l:Grid id="mainGrid" defaultSpan="XL12 L12 M12 S12" hSpacing="1" vSpacing="1" class="sapUiSmallMargin">
                <!-- Left Column: Input Forms (70%) -->
                <VBox id="formsContainer">
                    <layoutData>
                        <l:GridData span="XL8 L8 M12 S12"/>
                    </layoutData>

                    <!-- Employee Information Card -->
                    <Panel headerText="{i18n>employeeInfoSection}" class="sapUiSmallMarginBottom" backgroundDesign="Translucent">
                        <HBox wrap="Wrap" class="sapUiSmallMargin">
                            <VBox class="sapUiLargeMarginEnd sapUiTinyMarginBottom">
                                <Label text="{i18n>employeeName}" class="sapUiTinyMarginBottom"/>
                                <ObjectIdentifier title="{createForm>/employee/EmployeeName}" text="{= 'ID: ' + ${createForm>/employee/EmployeeID} }"/>
                            </VBox>
                            <VBox class="sapUiLargeMarginEnd sapUiTinyMarginBottom">
                                <Label text="Department" class="sapUiTinyMarginBottom"/>
                                <Text text="{createForm>/employee/DepartmentID}" design="Bold"/>
                            </VBox>
                            <VBox class="sapUiLargeMarginEnd sapUiTinyMarginBottom">
                                <Label text="Manager" class="sapUiTinyMarginBottom"/>
                                <Text text="{createForm>/employee/ManagerID}" design="Bold"/>
                            </VBox>
                        </HBox>
                    </Panel>

                    <!-- Leave Details Card -->
                    <Panel headerText="{i18n>leaveDetailsSection}" class="sapUiSmallMarginBottom" backgroundDesign="Translucent">
                        <f:SimpleForm editable="true" layout="ResponsiveGridLayout" labelSpanXL="3" labelSpanL="3" labelSpanM="3" labelSpanS="12">
                            <f:content>
                                <Label text="{i18n>leaveType}" required="true"/>
                                <ComboBox id="cmbLeaveType" 
                                    required="true"
                                    placeholder="Select Leave Type"
                                    selectedKey="{createForm>/leaveRequest/LeaveType}"
                                    selectionChange=".onLeaveTypeChange"
                                    items="{createForm>/leaveTypes}">
                                    <core:Item key="{createForm>LeaveType}" text="{createForm>LeaveName}"/>
                                </ComboBox>

                                <Label text="{i18n>startDate}" required="true"/>
                                <DatePicker id="dpStartDate" 
                                    required="true" 
                                    valueFormat="yyyy-MM-dd"
                                    displayFormat="yyyy-MM-dd"
                                    value="{createForm>/leaveRequest/StartDate}"
                                    change=".onDatesChange">
                                    <layoutData>
                                        <l:GridData span="XL5 L5 M5 S8"/>
                                    </layoutData>
                                </DatePicker>
                                <Select id="rbHalfDayPeriod"
                                    selectedKey="{createForm>/leaveRequest/StartSession}" 
                                    change=".onDatesChange">
                                    <layoutData>
                                        <l:GridData span="XL4 L4 M4 S4"/>
                                    </layoutData>
                                    <core:Item key="Full" text="Full Day"/>
                                    <core:Item key="Morning" text="Morning"/>
                                    <core:Item key="Afternoon" text="Afternoon"/>
                                </Select>

                                <Label text="{i18n>endDate}" required="true"/>
                                <DatePicker id="dpEndDate" 
                                    required="true" 
                                    valueFormat="yyyy-MM-dd"
                                    displayFormat="yyyy-MM-dd"
                                    value="{createForm>/leaveRequest/EndDate}"
                                    change=".onDatesChange">
                                    <layoutData>
                                        <l:GridData span="XL5 L5 M5 S8"/>
                                    </layoutData>
                                </DatePicker>
                                <Select selectedKey="{createForm>/leaveRequest/EndSession}" 
                                    change=".onDatesChange">
                                    <layoutData>
                                        <l:GridData span="XL4 L4 M4 S4"/>
                                    </layoutData>
                                    <core:Item key="Full" text="Full Day"/>
                                    <core:Item key="Morning" text="Morning"/>
                                    <core:Item key="Afternoon" text="Afternoon"/>
                                </Select>

                                <Label text="Approver" required="true"/>
                                <ComboBox id="cmbApprover"
                                    required="true"
                                    placeholder="Select Approver"
                                    selectedKey="{createForm>/leaveRequest/ApproverId}"
                                    selectionChange=".onApproverChange"
                                    items="{createForm>/managers}">
                                    <core:ListItem key="{createForm>ManagerUser}" text="{createForm>ManagerName}" additionalText="{createForm>ManagerUser}"/>
                                </ComboBox>
                            </f:content>
                        </f:SimpleForm>
                    </Panel>

                    <!-- Reason Card -->
                    <Panel headerText="{i18n>reasonSection}" class="sapUiSmallMarginBottom" backgroundDesign="Translucent">
                        <f:SimpleForm editable="true" layout="ResponsiveGridLayout" labelSpanXL="3" labelSpanL="3" labelSpanM="3" labelSpanS="12">
                            <f:content>
                                <Label text="{i18n>reason}"/>
                                <TextArea value="{createForm>/leaveRequest/Reason}" 
                                    rows="5" 
                                    growing="true"
                                    maxLength="500" 
                                    placeholder="Hãy nhập lý do xin nghỉ chi tiết của bạn tại đây (tối thiểu 5 ký tự)..."
                                    liveChange=".onDatesChange"/>
                            </f:content>
                        </f:SimpleForm>
                    </Panel>

                    <!-- Attachments Card -->
                    <Panel headerText="{i18n>attachmentsSection}" class="sapUiSmallMarginBottom" backgroundDesign="Translucent">
                        <VBox class="sapUiSmallMargin">
                            <unified:FileUploader id="createFileUploader"
                                buttonText="Browse..."
                                placeholder="Choose a PDF, DOC, DOCX, XLSX, JPG, JPEG, or PNG file..."
                                fileType="pdf,doc,docx,xlsx,jpg,jpeg,png"
                                maximumFileSize="10"
                                fileSizeExceeds=".onFileSizeExceeds"
                                typeMissmatch=".onTypeMismatch"
                                change=".onFileChange"
                                width="100%"/>
                            <MessageStrip
                                text="File will be uploaded automatically when you click Submit. Allowed: PDF, DOC, DOCX, XLSX, JPG, JPEG, PNG (max 10 MB)."
                                type="Information"
                                showIcon="true"
                                showCloseButton="false"
                                class="sapUiTinyMarginTop"/>
                        </VBox>
                    </Panel>
                </VBox>

                <!-- Right Column: Request Summary Card (30%) -->
                <Panel id="summaryPanel" headerText="{i18n>requestSummarySection}" backgroundDesign="Translucent" class="sapUiSmallMarginBottom">
                    <layoutData>
                        <l:GridData span="XL4 L4 M12 S12"/>
                    </layoutData>
                    <VBox class="sapUiContentPadding">
                        <HBox justify="SpaceBetween" class="sapUiSmallMarginBottom" alignItems="Center">
                            <Label text="Leave Type:" design="Bold"/>
                            <Text text="{createForm>/summary/LeaveType}"/>
                        </HBox>
                        <HBox justify="SpaceBetween" class="sapUiSmallMarginBottom" alignItems="Center">
                            <Label text="Duration:" design="Bold"/>
                            <Text text="{createForm>/summary/Duration}"/>
                        </HBox>
                        <HBox justify="SpaceBetween" class="sapUiSmallMarginBottom" alignItems="Center">
                            <Label text="Remaining Balance:" design="Bold"/>
                            <Text text="{createForm>/summary/RemainingBalance}"/>
                        </HBox>
                        <HBox justify="SpaceBetween" class="sapUiSmallMarginBottom" alignItems="Center">
                            <Label text="Approver:" design="Bold"/>
                            <Text text="{createForm>/summary/Approver}"/>
                        </HBox>
                        <HBox justify="SpaceBetween" class="sapUiSmallMarginBottom" alignItems="Center">
                            <Label text="Status:" design="Bold"/>
                            <ObjectStatus text="{createForm>/summary/Status}" state="Warning"/>
                        </HBox>
                    </VBox>
                </Panel>

                <!-- Right Column: Leave Balance Card (30%) -->
                <Panel headerText="Leave Balance" backgroundDesign="Translucent" class="sapUiSmallMarginBottom">
                    <layoutData>
                        <l:GridData span="XL4 L4 M12 S12"/>
                    </layoutData>
                    <List items="{/LeaveQuota}" noDataText="No leave balance data available">
                        <CustomListItem>
                            <VBox class="sapUiContentPadding">
                                <HBox justify="SpaceBetween" alignItems="Center">
                                    <Label text="{LeaveTypeName}" design="Bold"/>
                                    <Text text="{RemainingDays} / {TotalDays} Days"/>
                                </HBox>
                                <ProgressIndicator
                                    percentValue="{= ${TotalDays} > 0 ? (${RemainingDays} / ${TotalDays}) * 100 : 0 }"
                                    displayValue="{RemainingDays} Days Remaining"
                                    state="{= ${RemainingDays} > 5 ? 'Success' : ${RemainingDays} > 2 ? 'Warning' : 'Error' }"
                                    class="sapUiTinyMarginTop"/>
                            </VBox>
                        </CustomListItem>
                    </List>
                </Panel>
            </l:Grid>
        </content>
        <footer>
            <OverflowToolbar>
                <ToolbarSpacer/>
                <Button id="btnSubmit"
                    text="{i18n>submit}"
                    type="Emphasized"
                    press=".onSubmit"
                    enabled="{createForm>/employeeRegistered}"/>
                <Button id="btnCancel" text="{i18n>cancel}" type="Transparent" press=".onCancel"/>
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
