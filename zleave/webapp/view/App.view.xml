<mvc:View controllerName="zleave.zleave.controller.App"
    xmlns:html="http://www.w3.org/1999/xhtml"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m" xmlns:tnt="sap.tnt">
    <tnt:ToolPage id="toolPage" sideExpanded="true">
        <tnt:header>
            <tnt:ToolHeader id="appHeader">
                <Button
                    id="toggleSideNavBtn"
                    icon="sap-icon://menu"
                    type="Transparent"
                    press=".onToggleSidebar"
                    tooltip="Toggle Menu"/>
                <Title text="Leave Management System" level="H1"/>
                <ToolbarSpacer />
                <Button
                    id="userBtn"
                    icon="sap-icon://customer"
                    type="Transparent"
                    press=".onUserMenuPress"
                    tooltip="User Profile"/>
                <Button
                    id="logoutBtn"
                    icon="sap-icon://log"
                    type="Transparent"
                    press=".onLogoutPress"
                    tooltip="Log Out"/>
            </tnt:ToolHeader>
        </tnt:header>
        <tnt:sideContent>
            <tnt:SideNavigation id="sideNav" selectedKey="{ui>/selectedSection}" itemSelect=".onNavSelect">
                <tnt:item>
                    <tnt:NavigationList>
                        <tnt:NavigationListItem text="{i18n>dashboard}" key="dashboard" icon="sap-icon://home"/>
                        <tnt:NavigationListItem text="{i18n>requests}" key="requests" icon="sap-icon://employee"/>
                        <tnt:NavigationListItem text="{i18n>myLeaveCalendarTitle}" key="myLeaveCalendar" icon="sap-icon://calendar"/>
                        <tnt:NavigationListItem text="{i18n>teamCalendarTitle}" key="teamCalendar" icon="sap-icon://group" visible="{= ${ui>/currentUser/is_manager} === 'X' || ${ui>/currentUser/is_manager} === 'true' || ${ui>/currentUser/is_manager} === '1' || ${ui>/currentUser/is_admin} === 'X' || ${ui>/currentUser/is_hr} === 'X' }"/>
                        <tnt:NavigationListItem text="{i18n>createLeaveRequestTitle}" key="createRequest" icon="sap-icon://create"/>
                    </tnt:NavigationList>
                </tnt:item>
            </tnt:SideNavigation>
        </tnt:sideContent>
        <tnt:mainContents>
            <App id="app"/>
        </tnt:mainContents>
    </tnt:ToolPage>
</mvc:View>
